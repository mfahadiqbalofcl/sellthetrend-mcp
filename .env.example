# Copy to .env and fill in. NEVER commit .env. NEVER paste these in a chat.
STT_EMAIL=
STT_PASSWORD=

# true = invisible browser (normal). Set false the FIRST time / for manual login or captcha.
STT_HEADLESS=true

# Optional manual login: open a visible browser, log in by hand, then call the stt_save_session tool.
# STT_MANUAL_LOGIN=1

# --- Optional proxy (residential proxy recommended to avoid IP blocks) ---
# STT_PROXY_SERVER=http://host:port
# STT_PROXY_USERNAME=
# STT_PROXY_PASSWORD=

# --- Optional overrides (only if defaults stop working) ---
# STT_BASE_URL=https://www.sellthetrend.com
# STT_LOGIN_URL=https://www.sellthetrend.com/login
# STT_DASHBOARD_URL=https://www.sellthetrend.com/dashboard/desk
# STT_SEARCH_PATH=/dashboard/desk
# STT_CARD_SELECTOR=
# STT_WINNING_PATH=
